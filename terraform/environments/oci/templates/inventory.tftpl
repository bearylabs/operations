[k3s_server]
server ansible_host=${server_ip} ansible_user=${ssh_user}

[k3s_workers]
%{ for idx, ip in worker_ips ~}
worker-${idx + 1} ansible_host=${ip} ansible_user=${ssh_user}
%{ endfor ~}

[k3s_cluster:children]
k3s_server
k3s_workers

[k3s_cluster:vars]
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
