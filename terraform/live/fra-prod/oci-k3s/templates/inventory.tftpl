[control_plane]
fra-cp-01 ansible_host=${server_ip} ansible_user=${ssh_user}

[workers]
%{ for idx, ip in worker_ips ~}
fra-worker-0${idx + 1} ansible_host=${ip} ansible_user=${ssh_user}
%{ endfor ~}

[cluster:children]
control_plane
workers

[cluster:vars]
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
