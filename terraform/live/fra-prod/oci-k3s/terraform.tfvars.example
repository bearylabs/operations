# Copy to terraform.tfvars and fill in — never commit terraform.tfvars
tenancy_ocid     = "ocid1.tenancy.oc1..xxxxxxxxxx"
user_ocid        = "ocid1.user.oc1..xxxxxxxxxx"
fingerprint      = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "eu-frankfurt-1"
compartment_ocid = "ocid1.tenancy.oc1..xxxxxxxxxx"  # same as tenancy_ocid for root
ssh_public_key   = "ssh-ed25519 AAAA..."
cluster_name     = "k3s"
